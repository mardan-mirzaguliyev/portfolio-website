---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  pubDate?: Date;
}

const {
  title,
  description = 'Mardan Mirzaguliyev — Frontend Engineer specializing in data-driven interfaces, performance, and open-source tooling.',
  image = '/og-default.png',
  noIndex = false,
  type = 'website',
  pubDate,
} = Astro.props;

const siteUrl   = Astro.site ?? new URL('https://mmardan.com');
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage   = new URL(image, siteUrl).href;
const pageTitle = title === 'Home' ? 'Mardan Mirzaguliyev — Developer' : `${title} · Mardan`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- BLOCKING theme script — runs before first paint to prevent flash -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var dark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content={type} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content="Mardan Mirzaguliyev" />
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicons -->
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon"             type="image/png"     href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon"                      href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="min-h-screen flex flex-col text-zinc-900 dark:text-zinc-100">

    <!--
      Ambient radial glow orbs — fixed behind all content.
      Pure CSS, pointer-events-none, no JS, no layout cost.
    -->
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 overflow-hidden -z-10">
      <!-- Primary violet orb — top-center -->
      <div class="
        absolute -top-48 left-1/2 -translate-x-1/2
        h-[640px] w-[900px] rounded-full
        bg-violet-600/[0.09] dark:bg-violet-600/[0.10]
        blur-[130px]
        animate-pulse-glow
      "></div>
      <!-- Secondary indigo orb — bottom-right -->
      <div class="
        absolute -bottom-32 -right-32
        h-[480px] w-[560px] rounded-full
        bg-indigo-600/[0.06] dark:bg-indigo-500/[0.07]
        blur-[110px]
        animate-pulse-glow [animation-delay:1.5s]
      "></div>
      <!-- Tertiary fuchsia accent — mid-left -->
      <div class="
        absolute top-1/2 -left-24 -translate-y-1/2
        h-[320px] w-[320px] rounded-full
        bg-fuchsia-600/[0.04] dark:bg-fuchsia-500/[0.05]
        blur-[90px]
      "></div>
    </div>

    <Navbar />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
