---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  pubDate?: Date;
}

const {
  title,
  description = 'Mardan Mirzaguliyev — Frontend Engineer specializing in data-driven interfaces, performance, and open-source tooling.',
  image = '/og-default.png',
  noIndex = false,
  type = 'website',
  pubDate,
} = Astro.props;

const siteUrl   = Astro.site ?? new URL('https://your-domain.netlify.app');
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage   = new URL(image, siteUrl).href;
const pageTitle = title === 'Home' ? 'Mardan Mirzaguliyev — Developer' : `${title} · Mardan`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- BLOCKING theme script — must run before any paint to prevent flash -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var dark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content={type} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content="Mardan Mirzaguliyev" />
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicons -->
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon"             type="image/png"     href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon"                      href="/apple-touch-icon.png" />

    <!-- Generator tag (Astro adds this automatically in newer versions) -->
    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="min-h-screen flex flex-col bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100">
    <Navbar />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
