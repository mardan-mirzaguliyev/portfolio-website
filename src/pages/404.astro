---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noIndex={true}>
  <section class="mx-auto max-w-xl px-6 py-32 text-center">
    <p class="section-label mb-3">404</p>
    <h1 class="text-4xl font-bold text-zinc-900 dark:text-zinc-100 mb-4">Page not found</h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex justify-center gap-3">
      <a href="/" class="btn-primary">Go home</a>
      <a href="/projects" class="btn-ghost">View projects</a>
    </div>
  </section>
</BaseLayout>
