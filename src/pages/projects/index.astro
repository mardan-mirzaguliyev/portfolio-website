---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Collect unique tags for the filter UI (no JS fallback: all shown by default)
const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="A collection of my work — data visualisations, web apps, and open-source libraries."
>
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-8">
    <p class="section-label mb-3">Work</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-zinc-100 tracking-tight">
      All projects
    </h1>
    <p class="mt-3 text-zinc-500 dark:text-zinc-400 max-w-xl">
      {sorted.length} projects spanning data science, web tooling, and full-stack applications.
    </p>
  </section>

  <!-- Tag filter strip (progressive enhancement — JS optional) -->
  <section class="mx-auto max-w-5xl px-6 pb-8">
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by tag" id="tag-filters">
      <button
        data-tag="all"
        class="tag cursor-pointer data-[active]:bg-violet-100 data-[active]:dark:bg-violet-950/60 data-[active]:text-violet-600 data-[active]:dark:text-violet-400 data-[active]:border-violet-300 data-[active]:dark:border-violet-700 transition-colors duration-150"
        data-active
      >
        All
      </button>
      {allTags.map((tag) => (
        <button
          data-tag={tag}
          class="tag cursor-pointer data-[active]:bg-violet-100 data-[active]:dark:bg-violet-950/60 data-[active]:text-violet-600 data-[active]:dark:text-violet-400 data-[active]:border-violet-300 data-[active]:dark:border-violet-700 transition-colors duration-150"
        >
          {tag}
        </button>
      ))}
    </div>
  </section>

  <!-- Grid -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
      {sorted.map((project) => (
        <div data-tags={project.data.tags.join(',')}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            href={`/projects/${project.slug}`}
            image={project.data.image}
            liveUrl={project.data.liveUrl}
            repositoryUrl={project.data.repositoryUrl}
            featured={project.data.featured}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-tag]');
  const cards      = document.querySelectorAll<HTMLDivElement>('[data-tags]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;

      filterBtns.forEach((b) => delete b.dataset.active);
      btn.dataset.active = '';

      cards.forEach((card) => {
        const tags = card.dataset.tags!.split(',');
        card.style.display = (tag === 'all' || tags.includes(tag)) ? '' : 'none';
      });
    });
  });
</script>
