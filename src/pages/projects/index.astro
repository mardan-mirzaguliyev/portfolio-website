---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.title.localeCompare(b.data.title));

const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="A collection of my work — data visualisations, web apps, and open-source libraries."
>

  <!-- Page header with gradient accent line -->
  <section class="relative mx-auto max-w-5xl px-6 pt-20 pb-10">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden -z-10">
      <div class="absolute -top-24 right-0 h-[350px] w-[500px] rounded-full bg-indigo-600/[0.06] blur-[90px]"></div>
    </div>

    <p class="section-label mb-3">Work</p>
    <h1 class="text-4xl sm:text-5xl font-extrabold text-zinc-900 dark:text-zinc-50 tracking-tight mb-4">
      All projects
    </h1>
    <p class="text-zinc-500 dark:text-zinc-400 max-w-lg text-base leading-relaxed">
      <span class="font-semibold text-zinc-900 dark:text-zinc-100">{sorted.length}</span> projects spanning data science, web tooling, and full-stack applications.
    </p>
  </section>

  <!-- Tag filter strip -->
  <section class="mx-auto max-w-5xl px-6 pb-8">
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by tag" id="tag-filters">
      <button
        data-tag="all"
        data-active
        class="
          inline-block px-3 py-1 rounded-full text-xs font-semibold border cursor-pointer
          transition-all duration-150
          bg-violet-500/10 text-violet-600 dark:text-violet-400 border-violet-500/25
          data-[active]:bg-violet-500/15 data-[active]:border-violet-500/40
          hover:border-violet-500/40 hover:bg-violet-500/15
        "
      >
        All
      </button>
      {allTags.map((tag) => (
        <button
          data-tag={tag}
          class="
            inline-block px-3 py-1 rounded-full text-xs font-medium border cursor-pointer
            transition-all duration-150
            bg-zinc-100 dark:bg-zinc-800/70
            text-zinc-600 dark:text-zinc-400
            border-zinc-200 dark:border-zinc-700/50
            hover:bg-zinc-200/70 dark:hover:bg-white/[0.09]
            hover:text-zinc-900 dark:hover:text-zinc-100
            hover:border-zinc-300 dark:hover:border-white/[0.15]
            data-[active]:bg-violet-500/10 data-[active]:text-violet-600 data-[active]:dark:text-violet-400 data-[active]:border-violet-500/25
          "
        >
          {tag}
        </button>
      ))}
    </div>
  </section>

  <!-- Project grid -->
  <section class="mx-auto max-w-5xl px-6 pb-32">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
      {sorted.map((project) => (
        <div data-tags={project.data.tags.join(',')}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            href={`/projects/${project.slug}`}
            liveUrl={project.data.liveUrl}
            repositoryUrl={project.data.repositoryUrl}
            featured={project.data.featured}
          />
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-tag]');
  const cards      = document.querySelectorAll<HTMLDivElement>('[data-tags]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      filterBtns.forEach((b) => delete b.dataset.active);
      btn.dataset.active = '';
      cards.forEach((card) => {
        const tags = card.dataset.tags!.split(',');
        card.style.display = (tag === 'all' || tags.includes(tag)) ? '' : 'none';
      });
    });
  });
</script>
