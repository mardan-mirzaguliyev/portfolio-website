---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Technical writing on frontend engineering, data visualisation, and open-source development."
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="section-label mb-3">Writing</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-zinc-100 tracking-tight mb-10">
      Blog
    </h1>

    {posts.length === 0 && (
      <p class="text-zinc-500 dark:text-zinc-400">No posts published yet. Check back soon.</p>
    )}

    <ol class="space-y-px" role="list">
      {posts.map((post) => {
        const date = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric', month: 'short', day: 'numeric',
        });
        return (
          <li>
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col sm:flex-row sm:items-baseline justify-between gap-2 py-5 border-b border-zinc-200 dark:border-zinc-800 hover:pl-2 transition-all duration-150"
            >
              <div>
                <h2 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors duration-150 mb-1">
                  {post.data.title}
                </h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-xs text-zinc-400 dark:text-zinc-600 whitespace-nowrap sm:ml-8 shrink-0"
              >
                {date}
              </time>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>
