---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { label: 'Projects', href: '/projects' },
  { label: 'Blog',     href: '/blog'     },
  { label: 'Contact',  href: '/contact'  },
];

const currentPath = Astro.url.pathname;
---

<header class="
  sticky top-0 z-50 w-full
  border-b border-zinc-200/50 dark:border-white/[0.06]
  bg-zinc-50/75 dark:bg-zinc-950/75
  backdrop-blur-xl backdrop-saturate-150
  dark:shadow-[inset_0_-1px_0_rgba(255,255,255,0.04)]
">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4" aria-label="Main navigation">

    <!-- Wordmark -->
    <a
      href="/"
      class="group font-bold text-zinc-900 dark:text-zinc-100 tracking-tight transition-colors duration-150"
      aria-label="Home"
    >
      mmardan
      <span class="text-violet-500 group-hover:text-violet-400 transition-colors duration-150">.</span>
      <span class="group-hover:text-violet-500 transition-colors duration-150">com</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden sm:flex items-center gap-0.5" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a
              href={href}
              class:list={[
                'relative px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                isActive
                  ? [
                      'text-violet-600 dark:text-violet-300',
                      'bg-violet-50 dark:bg-violet-500/[0.12]',
                      'border border-violet-200/60 dark:border-violet-500/[0.2]',
                    ]
                  : [
                      'text-zinc-500 dark:text-zinc-400',
                      'hover:text-zinc-900 dark:hover:text-zinc-100',
                      'hover:bg-zinc-100/80 dark:hover:bg-white/[0.06]',
                      'border border-transparent',
                    ],
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="flex items-center gap-1.5">
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex h-9 w-9 items-center justify-center rounded-lg
               text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100
               hover:bg-zinc-100 dark:hover:bg-white/[0.07]
               border border-transparent dark:hover:border-white/[0.07]
               transition-all duration-150"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path id="menu-icon-open"  stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="
      hidden sm:hidden
      border-t border-zinc-200/60 dark:border-white/[0.06]
      bg-zinc-50/90 dark:bg-zinc-950/90
      backdrop-blur-xl px-4 pb-4
    "
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col gap-1 pt-3" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a
              href={href}
              class:list={[
                'flex items-center px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150',
                isActive
                  ? 'text-violet-600 dark:text-violet-300 bg-violet-50 dark:bg-violet-500/10 border border-violet-200/60 dark:border-violet-500/20'
                  : 'text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-white/[0.06] border border-transparent',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const btn   = document.getElementById('mobile-menu-btn')!;
  const menu  = document.getElementById('mobile-menu')!;
  const open  = document.getElementById('menu-icon-open')!;
  const close = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu.classList.toggle('hidden');
    open.classList.toggle('hidden');
    close.classList.toggle('hidden');
  });
</script>
