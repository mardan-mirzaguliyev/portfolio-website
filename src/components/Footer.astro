---
const year = new Date().getFullYear();

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/yourusername',
    icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/yourusername',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />`,
  },
  {
    label: 'Twitter / X',
    href: 'https://twitter.com/yourusername',
    icon: `<path d="M4 4l16 16M4 20L20 4" stroke-linecap="round" />`,
  },
];
---

<footer class="mt-auto border-t border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950">
  <div class="mx-auto max-w-5xl px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
    <!-- Left: wordmark + copyright -->
    <div class="text-center sm:text-left">
      <p class="font-semibold text-zinc-900 dark:text-zinc-100 text-sm">
        mardan<span class="text-violet-500">.</span>dev
      </p>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-500">
        &copy; {year} Mardan Mirzaguliyev. Built with Astro &amp; Tailwind.
      </p>
    </div>

    <!-- Right: social links -->
    <div class="flex items-center gap-3">
      {socialLinks.map(({ label, href, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-500 dark:text-zinc-500 hover:text-violet-600 dark:hover:text-violet-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors duration-150"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={icon}
          />
        </a>
      ))}
    </div>
  </div>
</footer>
